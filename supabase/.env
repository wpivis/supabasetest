# Your domain names (plain hostnames, no https://)
STUDY_DOMAIN=study.example.com
API_DOMAIN=api.example.com

# Supabase secrets — rotate ALL of these before going into production.
# To generate a new matched JWT_SECRET / ANON_KEY / SERVICE_ROLE_KEY set:
#   https://supabase.com/docs/guides/self-hosting#generate-api-keys
POSTGRES_PASSWORD=this-is-a-crazy-new-password-that-is-fine
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=my-dashboard-password-that-is-fine-too
JWT_SECRET=CcXRcIOHP8xjjVLvvvRPHdrRoErDO749roX8rW3p
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzcxNDg0NDAwLCJleHAiOjE5MjkyNTA4MDB9.35N9weBDFuf-37dj32FwA_k90vX4kdJfM_G97CSS8dU
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UiLCJpYXQiOjE3NzE0ODQ0MDAsImV4cCI6MTkyOTI1MDgwMH0.Lu6V5Fe0LEnsQ0CpXfiPVqMFvIUhlAeotPbwB0gOpYk

# ===================================================================
# OPTIONAL — Change only if you need these features
# ===================================================================

# GitHub OAuth — set CLIENT_ID and SECRET to enable; leave blank to disable
ENABLE_GITHUB_OAUTH=false
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_SECRET=

# Email confirmation via external SMTP.
# Leave SMTP_HOST as "supabase-mail" to use the built-in stub (no real email sent).
ENABLE_EMAIL_AUTOCONFIRM=true
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=fake_sender

# ===================================================================
# Derived — managed automatically by deploy/digitalocean/setup.sh
# Do not edit these manually; they are set from STUDY_DOMAIN / API_DOMAIN
# ===================================================================

SITE_URL=https://study.example.com
API_EXTERNAL_URL=https://api.example.com
SUPABASE_PUBLIC_URL=https://api.example.com
GITHUB_OAUTH_REDIRECT_URI=https://api.example.com/auth/v1/callback

# ===================================================================
# Internal — safe to leave as-is
# ===================================================================

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

PGRST_DB_SCHEMAS=public,storage,graphql_public

ADDITIONAL_REDIRECT_URLS=
JWT_EXPIRY=3600
DISABLE_SIGNUP=false

MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

ENABLE_EMAIL_SIGNUP=true
ENABLE_ANONYMOUS_USERS=true
ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true

STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project

LOGFLARE_API_KEY=your-super-secret-and-long-logflare-key
